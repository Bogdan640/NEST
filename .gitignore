# ==============================================================================
# Master .gitignore for NEST Platform (Angular Frontend + Node Backend)
# ==============================================================================

# =========================
# 1. Environment & Secrets
# =========================
.env
*.env
.env.development.local
.env.test.local
.env.production.local
.env.local
*.pem
*.cert
*.key

# =========================
# 2. Node Dependencies
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# 3. Backend (Node/Express/Prisma)
# =========================
backend/dist/
backend/build/
backend/logs/

# 3.1 Prisma & Custom Database
backend/dev.db
backend/dev.db-journal
**/*.db
**/*.db-journal

# 3.2 Testing & Coverage
backend/coverage/
backend/.nyc_output/

# =========================
# 4. Frontend (Angular)
# =========================
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/

# 4.1 Angular Testing & Caches
frontend/.angular/
frontend/coverage/

# =========================
# 5. OS & System Caches
# =========================
# Windows (Your Host OS)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS (For Collaborators)
.DS_Store
.AppleDouble
.LSOverride

# =========================
# 6. IDEs & Editors
# =========================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
